  classDef accent fill:#1a6b4a,color:#ffffff,stroke:#1a6b4a,stroke-width:1px;
  classDef ex fill:#ffffff,color:#111111,stroke:#3b4d63,stroke-width:1px;

  class CLIENT,SERVER dark;
  class CARD,SM light;
  class E1R,E2A accent;
  class E1P,E2P,E2T,E2G,E3P,E3I,E3C,E3D ex;
