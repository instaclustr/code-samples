flowchart LR
  %% Hero diagram — Part 5 blog: three Java demo examples

  CLIENT(("Clockwork\nClient"))
  SERVER(("Clockwork\nAgent"))

  CLIENT -->|"1 fetch"| CARD["Agent Card"]
  CARD --> SM["SendMessage"]

  SM --> E1
  SM --> E2
  SM --> E3

  subgraph E1["Ex 1 · Time"]
    direction TB
    E1P["What time?"] --> E1R["Message"]
  end

  subgraph E2["Ex 2 · Countdown"]
    direction TB
    E2P["Count down 60s"] --> E2T["Task"] --> E2G["GetTask poll"] --> E2A["Artifact"]
  end

  subgraph E3["Ex 3 · Confirm"]
    direction TB
    E3P["Count down + confirm"] --> E3I["input-required"]
    E3I --> E3C["SendMessage + taskId"]
    E3C --> E3D["working → completed"]
  end

  E1R & E2A & E3D --> CLIENT
  SM --> SERVER

