  classDef mid fill:#1a5276,color:#ffffff,stroke:#1a5276,stroke-width:1px;
  classDef sdk fill:#1a6b4a,color:#ffffff,stroke:#1a6b4a,stroke-width:1px;
  classDef fw fill:#eef3f8,color:#111111,stroke:#3b4d63,stroke-width:1px;
  classDef gap fill:#fdebd0,color:#111111,stroke:#e67e22,stroke-width:1px;

  class H head;
  class P1,P2 core;
  class B1,B2,B3 mid;
  class S1,S2 sdk;
  class F1,F2,F3,F4 fw;
  class A1,A2,A3 gap;
